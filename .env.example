# Voice Assistant Configuration

# Speech recognition engine: google, sphinx, whisper (default: google)
STT_ENGINE=google

# Text-to-speech engine: pyttsx3 (default: pyttsx3)
TTS_ENGINE=pyttsx3

# Language for speech recognition (default: en-US)
LANGUAGE=en-US

# Wake word to activate the assistant (default: assistant)
WAKE_WORD=assistant

# Enable wake word detection (true/false, default: false)
# When false, press Enter to start listening (push-to-talk mode)
WAKE_WORD_ENABLED=false

# Minimum audio energy threshold for detection (default: 300)
ENERGY_THRESHOLD=300

# Maximum seconds allowed for a single spoken phrase (default: 5)
PHRASE_TIME_LIMIT=5

# Microphone device index (leave empty for default device)
MIC_DEVICE_INDEX=

# Run in text-only mode (no microphone required, default: false)
# Useful for testing commands without audio hardware
TEXT_MODE=false

# OpenWeatherMap API key (required for weather commands)
# Get a free key at: https://openweathermap.org/api
WEATHER_API_KEY=
